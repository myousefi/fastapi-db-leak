# Runtime environment
ENVIRONMENT=local
PROJECT_NAME="FastAPI DB Leak Demo"
BACKEND_CORS_ORIGINS="http://localhost:8000"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Database settings
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Container image tag for the backend service
DOCKER_IMAGE_BACKEND=backend

# Observability (SigNoz / OpenTelemetry)
OTEL_TRACING_ENABLED=true
# Defaults to the SigNoz collector's gRPC endpoint when using the provided docker-compose setup.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME="fastapi-db-leak-api"
